# GraphShield Environment Configuration
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.

# ── Groq API ────────────────────────────────────────────────────────────────
# Required for LLM-powered patch recommendations.
# Get your key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Model to use for patch recommendations (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Storage Paths ────────────────────────────────────────────────────────────
# Directory where GraphShield stores its CVE database and Bloom filter.
# Defaults to ~/.graphshield if not set.
# GRAPHSHIELD_DIR=/home/user/.graphshield

# ── NVD Settings ─────────────────────────────────────────────────────────────
# How many hours before re-downloading the modified CVE feed.
# NVD_REFRESH_HOURS=24

# ── Scan Settings ────────────────────────────────────────────────────────────
# Maximum number of vulnerable packages to send to the LLM agent per scan.
# MAX_AGENT_CALLS_PER_SCAN=10

# ── Watchdog Settings ────────────────────────────────────────────────────────
# Webhook URL to POST alerts to (Slack, Discord, PagerDuty, etc.)
# WATCHDOG_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# GitHub integration — create issues on HIGH/CRITICAL alerts
# GITHUB_TOKEN=ghp_...
# WATCHDOG_GITHUB_REPO=owner/repo-name

# Minimum severity to dispatch (INFO | MEDIUM | HIGH | CRITICAL)
# WATCHDOG_MIN_SEVERITY=HIGH

# How often to poll the CVE database for new entries (seconds)
# WATCHDOG_POLL_INTERVAL=300
